root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false  # markdown uses trailing spaces for line breaks

[*.{json,jsonc}]
indent_size = 2

[*.{js,ts,mjs,cjs}]
indent_size = 2

[LICENSE]
insert_final_newline = false
